{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=bootcamp_api;Username=postgres;Password=example"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Auth": {
    "Mode": "local"
  },
  "Jwt": {
    "Authority": "https://your-auth-server.com",
    "Audience": "bootcamp-api",
    "Secret": "your-super-secret-key-for-jwt-signing-here"
  },
  "Oidc": {
    "Authority": "http://localhost:18082/realms/bootcamp",
    "Audience": "enrollmenthub-api",
    "RequireHttpsMetadata": false,
    "ValidateAudience": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
