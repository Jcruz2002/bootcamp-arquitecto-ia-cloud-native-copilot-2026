{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=bootcamp_api;Username=postgres;Password=example"
  },
  "Auth": {
    "Mode": "oidc"
  },
  "Oidc": {
    "Authority": "http://localhost:18082/realms/bootcamp",
    "Audience": "enrollmenthub-api",
    "RequireHttpsMetadata": false,
    "ValidateAudience": false,
    "DefaultProvider": "keycloak",
    "Providers": {
      "Keycloak": {
        "Authority": "http://localhost:18082/realms/bootcamp",
        "Audience": "enrollmenthub-api",
        "RequireHttpsMetadata": false,
        "ValidateAudience": false
      },
      "Google": {
        "Authority": "https://accounts.google.com",
        "Audience": "",
        "RequireHttpsMetadata": true,
        "ValidateAudience": false
      },
      "Entra": {
        "TenantId": "common",
        "Authority": "https://login.microsoftonline.com/common/v2.0",
        "Audience": "",
        "RequireHttpsMetadata": true,
        "ValidateAudience": false
      }
    }
  },
  "Jwt": {
    "Secret": "lab-local-secret-for-fallback-mode"
  }
}